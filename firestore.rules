rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Datos personales: solo el dueño puede leer y escribir su propio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard: cualquier usuario autenticado puede leer (ranking del grupo),
    // pero cada usuario solo puede escribir su propia entrada
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Todo lo demás denegado por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
